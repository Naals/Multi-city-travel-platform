# ============================================================
# Multi-City Travel Platform — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git
# ============================================================

# ===========================
# PostgreSQL — Auth Service
# ===========================
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5432
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_secret_pass

# ===========================
# PostgreSQL — User Service
# ===========================
USER_DB_HOST=localhost
USER_DB_PORT=5433
USER_DB_NAME=user_db
USER_DB_USER=user_user
USER_DB_PASSWORD=user_secret_pass

# ===========================
# PostgreSQL — Flight Service
# ===========================
FLIGHT_DB_HOST=localhost
FLIGHT_DB_PORT=5434
FLIGHT_DB_NAME=flight_db
FLIGHT_DB_USER=flight_user
FLIGHT_DB_PASSWORD=flight_secret_pass

# ===========================
# PostgreSQL — Booking Service
# ===========================
BOOKING_DB_HOST=localhost
BOOKING_DB_PORT=5435
BOOKING_DB_NAME=booking_db
BOOKING_DB_USER=booking_user
BOOKING_DB_PASSWORD=booking_secret_pass

# ===========================
# PostgreSQL — Payment Service
# ===========================
PAYMENT_DB_HOST=localhost
PAYMENT_DB_PORT=5436
PAYMENT_DB_NAME=payment_db
PAYMENT_DB_USER=payment_user
PAYMENT_DB_PASSWORD=payment_secret_pass

# ===========================
# PostgreSQL — Review Service
# ===========================
REVIEW_DB_HOST=localhost
REVIEW_DB_PORT=5437
REVIEW_DB_NAME=review_db
REVIEW_DB_USER=review_user
REVIEW_DB_PASSWORD=review_secret_pass

# ===========================
# Redis
# ===========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_pass

# ===========================
# Kafka
# ===========================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ZOOKEEPER_CONNECT=localhost:2181

# ===========================
# RabbitMQ
# ===========================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=rabbit_user
RABBITMQ_PASSWORD=rabbit_secret_pass
RABBITMQ_VHOST=travel_vhost
RABBITMQ_MANAGEMENT_PORT=15672

# ===========================
# JWT
# ===========================
JWT_SECRET=your_super_secret_jwt_key_min_256_bits_long_change_this
JWT_ACCESS_TOKEN_EXPIRY_MS=900000
JWT_REFRESH_TOKEN_EXPIRY_SECONDS=604800

# ===========================
# Zipkin
# ===========================
ZIPKIN_BASE_URL=http://localhost:9411

# ===========================
# Service Ports
# ===========================
CONFIG_SERVER_PORT=8888
EUREKA_SERVER_PORT=8761
API_GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
FLIGHT_SERVICE_PORT=8083
BOOKING_SERVICE_PORT=8084
PAYMENT_SERVICE_PORT=8085
REVIEW_SERVICE_PORT=8086
NOTIFICATION_SERVICE_PORT=8087

# ===========================
# Eureka
# ===========================
EUREKA_SERVER_URL=http://localhost:8761/eureka

# ===========================
# Config Server
# ===========================
CONFIG_SERVER_URL=http://localhost:8888

# ===========================
# Grafana
# ===========================
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_secret_pass

# ===========================
# Prometheus
# ===========================
PROMETHEUS_PORT=9090
